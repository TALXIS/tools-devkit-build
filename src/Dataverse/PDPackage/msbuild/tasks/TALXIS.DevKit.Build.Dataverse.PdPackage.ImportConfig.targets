<Project>
  <PropertyGroup>
    <!-- _SourceImportConfigPath: path to user-defined ImportConfig.xml in PkgAssets. -->
    <_SourceImportConfigPath>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)','PkgAssets','ImportConfig.xml'))</_SourceImportConfigPath>
  </PropertyGroup>

  <!-- Runs before GeneratePdImportConfig; detects a custom ImportConfig.xml and skips auto-generation if found. -->
  <Target Name="_DetectCustomImportConfig"
          BeforeTargets="GeneratePdImportConfig"
          Condition="'$(AutoGeneratePdImportConfig)'=='true' and Exists('$(_SourceImportConfigPath)')">

    <XmlPeek XmlInputPath="$(_SourceImportConfigPath)"
             Query="//configsolutionfile">
      <Output TaskParameter="Result" ItemName="_DetectedSolutionFilesInImportConfig" />
    </XmlPeek>

    <PropertyGroup Condition="'@(_DetectedSolutionFilesInImportConfig)'!=''">
      <AutoGeneratePdImportConfig>false</AutoGeneratePdImportConfig>
    </PropertyGroup>

    <Message Text="Detected custom ImportConfig.xml with configsolutionfile elements - skipping auto-generation, using user-defined config."
             Importance="High"
             Condition="'@(_DetectedSolutionFilesInImportConfig)'!=''" />
  </Target>

  <!-- Runs after UpdatePdImportConfigToGenerated; post-processes the generated ImportConfig with solution annotations and CMT data. -->
  <Target Name="_PostProcessImportConfig"
          AfterTargets="UpdatePdImportConfigToGenerated"
          BeforeTargets="_PrepareCmtMetadataBeforePublish"
          DependsOnTargets="GeneratePdImportConfig;_AnnotateSolutions;DiscoverCmtPackages"
          Condition="'$(AutoGeneratePdImportConfig)'=='true' and Exists('$(_GeneratedPdImportConfig)')">

    <PropertyGroup>
      <_CmtDataZipFileNameForImportConfig Condition="'@(_CmtPackageDirs)'!=''">$(CmtMetadataZipFileName)</_CmtDataZipFileNameForImportConfig>
    </PropertyGroup>

    <PostProcessImportConfig
      ImportConfigPath="$(_GeneratedPdImportConfig)"
      Solutions="@(_AnnotatedSolution)"
      CmtDataFileName="$(_CmtDataZipFileNameForImportConfig)" />
  </Target>
</Project>
