<Project>
  <PropertyGroup>
    <ProjectType Condition="'$(ProjectType)'==''">ScriptLibrary</ProjectType>
    <ScriptLibraryMainFile Condition="'$(ScriptLibraryMainFile)'==''">main</ScriptLibraryMainFile>
    <ScriptLibraryName Condition="'$(ScriptLibraryName)'==''">$(ScriptLibraryMainFile)</ScriptLibraryName>
    <LangVersion Condition="'$(LangVersion)'==''">latest</LangVersion>
    <GenerateAssemblyInfo Condition="'$(GenerateAssemblyInfo)'==''">false</GenerateAssemblyInfo>
  </PropertyGroup>
</Project>
