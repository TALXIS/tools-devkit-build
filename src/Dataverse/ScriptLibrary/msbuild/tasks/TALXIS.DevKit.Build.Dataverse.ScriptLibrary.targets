<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <TypeScriptDir Condition="'$(TypeScriptDir)'==''">$(MSBuildProjectDirectory)/TS</TypeScriptDir>

    <RunNodeBuild Condition="'$(RunNodeBuild)'=='' and Exists('$(TypeScriptDir)/package.json')">true</RunNodeBuild>
    <RunNodeBuild Condition="'$(RunNodeBuild)'==''">false</RunNodeBuild>
    <NodeEnvironment Condition="'$(NodeEnvironment)'=='' and '$(Configuration)'=='Release'">production</NodeEnvironment>
    <NodeEnvironment Condition="'$(NodeEnvironment)'==''">development</NodeEnvironment>
  </PropertyGroup>

  <Target Name="InstallScriptLibraryPackagesWithLock"
    DependsOnTargets="CheckScriptLibraryPrereqs"
    Inputs="$(TypeScriptDir)/package-lock.json"
    Outputs="$(TypeScriptDir)/node_modules/.package-lock.json"
    Condition="'$(RunNodeBuild)'=='true' and Exists('$(TypeScriptDir)/package-lock.json')">
    <Message Text="Installing ScriptLibrary npm packages in $(TypeScriptDir)" Importance="High" />
    <RunNodeTool FileName="npm" Arguments="ci" WorkingDirectory="$(TypeScriptDir)" IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_ScriptLibraryNpmCiExitCode" />
    </RunNodeTool>
    <Warning Condition="'$(_ScriptLibraryNpmCiExitCode)'!='0'" Text="npm ci failed with exit code $(_ScriptLibraryNpmCiExitCode); falling back to npm install. Lockfile integrity problems may be hidden by the fallback." />
    <RunNodeTool FileName="npm" Arguments="install" WorkingDirectory="$(TypeScriptDir)"
                 Condition="'$(_ScriptLibraryNpmCiExitCode)'!='0'" />
  </Target>

  <Target Name="InstallScriptLibraryPackagesWithoutLock"
    DependsOnTargets="CheckScriptLibraryPrereqs"
    Inputs="$(TypeScriptDir)/package.json"
    Outputs="$(TypeScriptDir)/node_modules/.package-lock.json"
    Condition="'$(RunNodeBuild)'=='true' and !Exists('$(TypeScriptDir)/package-lock.json')">
    <Message Text="Installing ScriptLibrary npm packages in $(TypeScriptDir)" Importance="High" />
    <RunNodeTool FileName="npm" Arguments="install" WorkingDirectory="$(TypeScriptDir)" />
  </Target>

  <Target Name="BuildTypeScript"
    DependsOnTargets="CheckScriptLibraryPrereqs;InstallScriptLibraryPackagesWithLock;InstallScriptLibraryPackagesWithoutLock"
    BeforeTargets="Build"
    Condition="'$(RunNodeBuild)'=='true'">
    <Message Text="Building TypeScript in $(TypeScriptDir)" Importance="High" />
    <RunNodeTool FileName="npm" Arguments="run build" WorkingDirectory="$(TypeScriptDir)"
                 EnvironmentVariables="NODE_ENV=$(NodeEnvironment)" />
  </Target>
  
  <Target Name="CheckScriptLibraryPrereqs"
    Condition="'$(RunNodeBuild)'=='true'">
    <Error Condition="!Exists('$(TypeScriptDir)')" Text="ScriptLibrary TS directory not found: $(TypeScriptDir)" />
    <Error Condition="!Exists('$(TypeScriptDir)/package.json')" Text="ScriptLibrary package.json not found in $(TypeScriptDir)" />
    <RunNodeTool FileName="node" Arguments="--version" IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_ScriptLibraryNodeVersionExitCode" />
    </RunNodeTool>
    <Error Condition="'$(_ScriptLibraryNodeVersionExitCode)'!='0'" Text="Node.js not found in PATH. Install Node.js to build ScriptLibrary." />
    <RunNodeTool FileName="npm" Arguments="--version" IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_ScriptLibraryNpmVersionExitCode" />
    </RunNodeTool>
    <Error Condition="'$(_ScriptLibraryNpmVersionExitCode)'!='0'" Text="npm not found in PATH. Install Node.js (includes npm) to build ScriptLibrary." />
  </Target>

  <ItemGroup>
    <None Include="$(TypeScriptDir)/build/**/*.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Target Name="GetProjectType" Returns="@(_ProjectType)" Condition="'$(ProjectType)'!=''">
    <ItemGroup>
      <_ProjectType Include="$(MSBuildProjectFullPath)">
        <ProjectType>$(ProjectType)</ProjectType>
      </_ProjectType>
    </ItemGroup>
  </Target>

  <Target Name="GetScriptLibraryOutputs"
    DependsOnTargets="Build"
    Returns="@(_ScriptLibraryOutputs)">
    <ItemGroup>
      <_ScriptLibraryOutputs Include="$(TargetDir)$(ScriptLibraryName).js" />
    </ItemGroup>
  </Target>

  <Target Name="CopyScriptLibraryMainToOutput"
    AfterTargets="Build">
    <ItemGroup>
      <_ScriptLibraryMainFile Include="$(TypeScriptDir)/**/$(ScriptLibraryName).js" />
    </ItemGroup>
    <Message Text="Copying script library main file to $(TargetDir): @(_ScriptLibraryMainFile)" Importance="High" Condition="'@(_ScriptLibraryMainFile)'!=''" />
    <Copy SourceFiles="@(_ScriptLibraryMainFile)" DestinationFiles="@(_ScriptLibraryMainFile->'$(TargetDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" Condition="'@(_ScriptLibraryMainFile)'!=''" />
  </Target>

  <!--
    A ScriptLibrary project can opt into one of two relationships with each
    of its ProjectReference entries to another ScriptLibrary project:

      Separate     (default) both deploy as own web resources
      CompileOnly  the referenced project still builds (so its .d.ts is
                   available for /// <reference> in our TS), but its .js
                   is not deployed by the Solution that consumes us

    The Solution package reads GetSuppressedScriptLibraryReferences below
    to learn which references must NOT be deployed as their own web
    resources.
  -->

  <Target Name="GetSuppressedScriptLibraryReferences"
          Returns="@(_SuppressedScriptLibraryReferences)">
    <ItemGroup>
      <_SuppressedScriptLibraryReferences
          Include="@(ProjectReference->'%(FullPath)')"
          Condition="'%(ProjectReference.ScriptLibraryMode)' == 'CompileOnly'" />
    </ItemGroup>
  </Target>

</Project>
