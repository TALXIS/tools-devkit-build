<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <TypeScriptDir Condition="'$(TypeScriptDir)'==''">$(MSBuildProjectDirectory)/TS</TypeScriptDir>
    <NodeProjectDirectory Condition="'$(NodeProjectDirectory)'==''">$(TypeScriptDir)</NodeProjectDirectory>
  </PropertyGroup>

  <Target Name="BuildTypeScript"
    DependsOnTargets="NodeInstallPackagesWithLock;NodeInstallPackagesWithoutLock"
    BeforeTargets="Build"
    Condition="'$(RunNodeBuild)'=='true'">
    <Error Condition="!Exists('$(TypeScriptDir)')" Text="ScriptLibrary TS directory not found: $(TypeScriptDir)" />
    <Message Text="Building TypeScript in $(TypeScriptDir)" Importance="High" />
    <RunNodeTool FileName="npm" Arguments="run $(NodeBuildScript)" WorkingDirectory="$(TypeScriptDir)"
                 EnvironmentVariables="NODE_ENV=$(NodeEnvironment);BUILD_OUTPUT_DIR=$(NodeBuildOutputDir)" />
  </Target>

  <ItemGroup>
    <None Include="$(TypeScriptDir)/build/**/*.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Target Name="GetProjectType" Returns="@(_ProjectType)" Condition="'$(ProjectType)'!=''">
    <ItemGroup>
      <_ProjectType Include="$(MSBuildProjectFullPath)">
        <ProjectType>$(ProjectType)</ProjectType>
      </_ProjectType>
    </ItemGroup>
  </Target>

  <Target Name="GetScriptLibraryOutputs"
    DependsOnTargets="Build"
    Returns="@(_ScriptLibraryOutputs)">
    <ItemGroup>
      <_ScriptLibraryOutputs Include="$(TargetDir)$(ScriptLibraryName).js" />
    </ItemGroup>
  </Target>

  <Target Name="CopyScriptLibraryMainToOutput"
    AfterTargets="Build">
    <ItemGroup>
      <_ScriptLibraryMainFile Include="$(TypeScriptDir)/**/$(ScriptLibraryName).js" />
    </ItemGroup>
    <Message Text="Copying script library main file to $(TargetDir): @(_ScriptLibraryMainFile)" Importance="High" Condition="'@(_ScriptLibraryMainFile)'!=''" />
    <Copy SourceFiles="@(_ScriptLibraryMainFile)" DestinationFiles="@(_ScriptLibraryMainFile->'$(TargetDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" Condition="'@(_ScriptLibraryMainFile)'!=''" />
  </Target>

  <!--
    A ScriptLibrary project can opt into one of two relationships with each
    of its ProjectReference entries to another ScriptLibrary project:

      Separate     (default) both deploy as own web resources
      CompileOnly  the referenced project still builds (so its .d.ts is
                   available for /// <reference> in our TS), but its .js
                   is not deployed by the Solution that consumes us

    The Solution package reads GetSuppressedScriptLibraryReferences below
    to learn which references must NOT be deployed as their own web
    resources.
  -->

  <Target Name="GetSuppressedScriptLibraryReferences"
          Returns="@(_SuppressedScriptLibraryReferences)">
    <ItemGroup>
      <_SuppressedScriptLibraryReferences
          Include="@(ProjectReference->'%(FullPath)')"
          Condition="'%(ProjectReference.ScriptLibraryMode)' == 'CompileOnly'" />
    </ItemGroup>
  </Target>

</Project>
