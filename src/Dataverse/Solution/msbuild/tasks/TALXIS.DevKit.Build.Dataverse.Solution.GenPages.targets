<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Target Name="GenPageProbeProjectReferences"
          BeforeTargets="PrepareProjectReferences;ResolveProjectReferences;GenPageBuildProjectReferences"
          Condition="'@(ProjectReference)'!='' and '@(_GenPageProjects)'==''">

    <ItemGroup>
      <_ProjectTypeFromReferences Remove="@(_ProjectTypeFromReferences)" />
    </ItemGroup>

    <MSBuild Projects="@(ProjectReference->'%(FullPath)')"
             Targets="GetProjectType"
             Properties="Configuration=$(Configuration)"
             BuildInParallel="true"
             SkipNonexistentTargets="true">
      <Output TaskParameter="TargetOutputs" ItemName="_ProjectTypeFromReferences" />
    </MSBuild>

    <ItemGroup>
      <_GenPageProjects Remove="@(_GenPageProjects)" />
      <_GenPageProjects Include="@(_ProjectTypeFromReferences)"
                        Condition="'%(ProjectType)'=='GenPage'"
                        KeepDuplicates="false" />
    </ItemGroup>

    <PropertyGroup>
      <_GenPageProjectsList>;@(_GenPageProjects->'%(Identity)');</_GenPageProjectsList>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Remove="@(ProjectReference)"
                        Condition="$([System.String]::Copy('$(_GenPageProjectsList)').ToLowerInvariant().Contains($([System.String]::Copy(';%(FullPath);').ToLowerInvariant())))" />
    </ItemGroup>

    <Message Importance="high"
             Text="Detected GenPage projects: @(_GenPageProjects)"
             Condition="'@(_GenPageProjects)'!=''" />
  </Target>

  <Target Name="GenPageBuildProjectReferences"
          BeforeTargets="CoreCompile"
          DependsOnTargets="GenPageProbeProjectReferences"
          Condition="'@(_GenPageProjects)'!=''">

    <ItemGroup>
      <_GenPageOutput Remove="@(_GenPageOutput)" />
      <GenPageRef Remove="@(GenPageRef)" />
    </ItemGroup>

    <MSBuild Projects="@(_GenPageProjects)"
             Targets="GenPageGetOutputs"
             Properties="Configuration=$(Configuration)"
             BuildInParallel="true">
      <Output TaskParameter="TargetOutputs" ItemName="_GenPageOutput" />
    </MSBuild>

    <ItemGroup>
      <GenPageRef Include="@(_GenPageOutput)">
        <PageName>%(_GenPageOutput.PageName)</PageName>
        <CompiledJsPath>%(_GenPageOutput.CompiledJsPath)</CompiledJsPath>
        <EntrySourcePath>%(_GenPageOutput.EntrySourcePath)</EntrySourcePath>
        <ConfigJsonPath>%(_GenPageOutput.ConfigJsonPath)</ConfigJsonPath>
        <FirstPromptJsonPath>%(_GenPageOutput.FirstPromptJsonPath)</FirstPromptJsonPath>
        <OwningProjectPath>%(_GenPageOutput.OwningProjectPath)</OwningProjectPath>
      </GenPageRef>
    </ItemGroup>

    <Message Importance="high"
             Text="GenPage outputs: @(GenPageRef->'%(PageName) from %(OwningProjectPath)', ', ')"
             Condition="'@(GenPageRef)'!=''" />
  </Target>

  <Target Name="GenPageEnsureDeclarationsInSource"
          BeforeTargets="CopyCdsSolutionContent"
          DependsOnTargets="GenPageBuildProjectReferences"
          Condition="'@(GenPageRef)'!=''">

    <PropertyGroup>
      <_GenPageSolutionRoot>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)/$(SolutionRootPath)'))</_GenPageSolutionRoot>
    </PropertyGroup>

    <ItemGroup>
      <_DeclaredGenPage Remove="@(_DeclaredGenPage)" />
    </ItemGroup>

    <GenPageEnsureDeclarations SolutionRoot="$(_GenPageSolutionRoot)"
                               CustomizationsXmlPath="$(_GenPageSolutionRoot)/Other/Customizations.xml"
                               Pages="@(GenPageRef)">
      <Output TaskParameter="DeclaredPages" ItemName="_DeclaredGenPage" />
    </GenPageEnsureDeclarations>

  </Target>

  <Target Name="GenPageProjectToMetadata"
          AfterTargets="CopyCdsSolutionContent"
          BeforeTargets="ProcessCdsProjectReferencesOutputs"
          DependsOnTargets="GenPageEnsureDeclarationsInSource"
          Condition="'@(_DeclaredGenPage)'!=''">

    <GenPageProjectNativeTree MetadataRoot="$(SolutionPackagerMetadataWorkingDirectory)"
                              Pages="@(_DeclaredGenPage)" />
  </Target>

</Project>
