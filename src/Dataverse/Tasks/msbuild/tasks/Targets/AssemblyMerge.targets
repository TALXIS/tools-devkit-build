<?xml version="1.0" encoding="utf-8"?>

<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Assemblies to exclude from merging. Override in your .csproj to customize.
       Prefix-based exclusions (Microsoft.Xrm.Sdk.*, System.*) are always applied. -->
  <PropertyGroup>
    <AssemblyMergeExcludes Condition="'$(AssemblyMergeExcludes)' == ''">mscorlib;netstandard;Newtonsoft.Json;Microsoft.Xrm.Sdk;Microsoft.Crm.Sdk.Proxy</AssemblyMergeExcludes>
    <_AssemblyMergeExcludesPadded>;$(AssemblyMergeExcludes);</_AssemblyMergeExcludesPadded>
  </PropertyGroup>

  <!-- Pure callable worker: merges $(OutDir)*.dll into $(AssemblyName).dll
       via ILRepack, skipping sandbox-provided assemblies. Reads raw output
       from $(IntermediateOutputPath) so it's safe to re-run.
       No AfterTargets — Plugin/WorkflowActivity packages wire it up. -->
  <Target Name="AssemblyMergeDependencies">
    <PropertyGroup>
      <!-- _AssemblyMergeUnmergedPrimaryFromObj: unmerged assembly from obj/, used as ILRepack input. -->
      <_AssemblyMergeUnmergedPrimaryFromObj>$(IntermediateOutputPath)$(AssemblyName).dll</_AssemblyMergeUnmergedPrimaryFromObj>
      <!-- _AssemblyMergeOutputPath: final merged assembly written to the output directory. -->
      <_AssemblyMergeOutputPath>$(OutDir)$(AssemblyName).dll</_AssemblyMergeOutputPath>
    </PropertyGroup>
    <ItemGroup>
      <!-- _AssemblyMergeAllOutputDlls: all DLLs in the output directory. -->
      <_AssemblyMergeAllOutputDlls Include="$(OutDir)*.dll" />
      <!-- _AssemblyMergePrimaryDllInOutputDir: the main assembly DLL (excluded from merge inputs). -->
      <_AssemblyMergePrimaryDllInOutputDir Include="@(_AssemblyMergeAllOutputDlls)"
                           Condition=" '%(Filename)%(Extension)' == '$(AssemblyName).dll' " />
      <!-- _AssemblyMergeDependenciesToFold: dependency DLLs to merge into the primary assembly. -->
      <_AssemblyMergeDependenciesToFold Include="@(_AssemblyMergeAllOutputDlls)" Exclude="@(_AssemblyMergePrimaryDllInOutputDir)" />
      <!-- Drop excluded assemblies (configurable list + hard-coded prefix patterns). -->
      <_AssemblyMergeDependenciesToFold Remove="@(_AssemblyMergeDependenciesToFold)"
                        Condition="$(_AssemblyMergeExcludesPadded.Contains(';%(Filename);'))
                                 Or $([System.String]::Copy('%(Filename)').StartsWith('Microsoft.Xrm.Sdk.'))
                                 Or $([System.String]::Copy('%(Filename)').StartsWith('System.'))" />
    </ItemGroup>

    <Message Importance="high"
             Text="AssemblyMergeDependencies: merging into $(AssemblyName).dll -> @(_AssemblyMergeDependenciesToFold->'%(Filename)', ', ')"
             Condition=" '@(_AssemblyMergeDependenciesToFold)' != '' " />
    <Message Importance="high"
             Text="AssemblyMergeDependencies: nothing to merge"
             Condition=" '@(_AssemblyMergeDependenciesToFold)' == '' " />

    <!-- Internalize=false: keep public type names so Dataverse reflection
         still finds IPlugin / CodeActivity types. -->
    <!-- LibraryPath needs the absolute path to OutDir so Mono.Cecil's
         resolver finds referenced assemblies regardless of CWD. -->
    <ILRepack Condition=" '@(_AssemblyMergeDependenciesToFold)' != '' "
              Parallel="true"
              Internalize="false"
              InputAssemblies="$(_AssemblyMergeUnmergedPrimaryFromObj);@(_AssemblyMergeDependenciesToFold)"
              OutputFile="$(_AssemblyMergeOutputPath)"
              KeyFile="$(AssemblyOriginatorKeyFile)"
              LibraryPath="$([System.IO.Path]::GetFullPath('$(OutDir)'))" />
  </Target>

</Project>
