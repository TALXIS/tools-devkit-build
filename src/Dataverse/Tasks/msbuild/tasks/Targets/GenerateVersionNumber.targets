<Project>
	<PropertyGroup>
		<!-- When true (default), a sensible default ApplyToBranches value is
		     provided so Git versioning works out of the box on common branch
		     layouts. Set to false to opt out — ApplyToBranches stays empty
		     unless the consumer sets it explicitly, in which case
		     GenerateGitVersion falls back to LocalBranchBuildVersionNumber.
		     This flag only controls whether a default is filled in; an explicit
		     user-provided ApplyToBranches always wins regardless of its value. -->
		<EnableDefaultBranchVersioning Condition="'$(EnableDefaultBranchVersioning)' == ''">true</EnableDefaultBranchVersioning>

		<!-- Sensible default so Git versioning works out of the box on common branch
		     layouts. Override <ApplyToBranches> in the consuming project for custom
		     prefix assignments (e.g. "master:1;develop:2;pr/*:3"). Only applied
		     when EnableDefaultBranchVersioning is true. -->
		<ApplyToBranches Condition="'$(ApplyToBranches)' == '' and '$(EnableDefaultBranchVersioning)' == 'true'">main:1;master:1;develop:2;</ApplyToBranches>
	</PropertyGroup>
	<Target Name="GenerateVersionNumber">
		<Error Text="Version element in your project file is missing. You must declare a version number in order to specify major and minor numbers." Condition=" '$(Version)' == '' " />
		<RetrieveProjectReferences CurrentProjectFullPath="$(MSBuildProjectFullPath)">
			<Output TaskParameter="ReferencedProjects" ItemName="AllReferences"/>
		</RetrieveProjectReferences>
		<!-- <ItemGroup><AllReferencePaths Include="$([System.IO.Path]::GetDirectoryName(%(AllReferences.Identity)))" /></ItemGroup>
        <Message Text="Referenced Projects: %(AllReferences.Identity)" Importance="high" />
        <Message Text="Referenced Projects Folders: %(AllReferencePaths.Identity)" Importance="high" /> -->
		<GenerateGitVersion
			VersionMajor="$(Version.Split('.')[0])"
			VersionMinor="$(Version.Split('.')[1])"
			ProjectPath="$(ProjectDir)"
			ProjectFileName="$(ProjectFileName)"
			ApplyToBranches="$(ApplyToBranches)"
			Version="$(Version)"
			LocalBranchBuildVersionNumber="$(LocalBranchBuildVersionNumber)"
		>
			<Output TaskParameter="VersionOutput" PropertyName="Version"/>
			<Output TaskParameter="LastCommitDateTimeOutput" PropertyName="LastCommitDateTime"/>
		</GenerateGitVersion>
		<Message Text="Git-generated version number: $(Version)" Importance="high" />
		<Message Text="Last commit date and time: $(LastCommitDateTime)" Importance="high" />
	</Target>
</Project>