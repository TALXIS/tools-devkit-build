<?xml version="1.0" encoding="utf-8"?>

<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Path to the no-op stub. Consumer packages assign it to
       $(ILRepackTargetsFile) to silence ILRepack.Lib.MSBuild.Task's own
       auto-merge target. Just a path — no behavior on its own. -->
  <PropertyGroup>
    <TalxisILRepackStub Condition="'$(TalxisILRepackStub)' == ''">$(MSBuildThisFileDirectory)..\StubForILRepack.targets</TalxisILRepackStub>

    <!-- Semicolon-separated filenames (no extension) skipped from the merge.
         Default = assemblies provided by the Dataverse plugin / workflow-activity
         sandbox. Consumers override (e.g. PdPackage drops 'Newtonsoft.Json' to
         force it into the merged output). -->
    <TalxisILRepackExcludeFilenames Condition="'$(TalxisILRepackExcludeFilenames)' == ''">mscorlib;netstandard;Newtonsoft.Json;Microsoft.Xrm.Sdk;Microsoft.Crm.Sdk.Proxy</TalxisILRepackExcludeFilenames>
  </PropertyGroup>

  <!-- Pure callable: merges $(OutDir)*.dll into $(AssemblyName).dll via
       ILRepack. Drops $(TalxisILRepackExcludeFilenames) and the built-in
       System.* / Microsoft.Xrm.Sdk.* runtime prefixes. Reads raw output from
       $(IntermediateOutputPath) so it's safe to re-run.
       No AfterTargets — Plugin/WorkflowActivity/PdPackage packages wire it up. -->
  <Target Name="TalxisMergeOutputAssembly">
    <PropertyGroup>
      <_TalxisMergePrimaryRaw>$(IntermediateOutputPath)$(AssemblyName).dll</_TalxisMergePrimaryRaw>
      <_TalxisMergeOutputDll>$(OutDir)$(AssemblyName).dll</_TalxisMergeOutputDll>
      <_TalxisILRepackExcludePadded>;$(TalxisILRepackExcludeFilenames);</_TalxisILRepackExcludePadded>
    </PropertyGroup>
    <ItemGroup>
      <_TalxisMergeAll Include="$(OutDir)*.dll" />
      <_TalxisMergePrimary Include="@(_TalxisMergeAll)"
                           Condition=" '%(Filename)%(Extension)' == '$(AssemblyName).dll' " />
      <_TalxisMergeDeps Include="@(_TalxisMergeAll)" Exclude="@(_TalxisMergePrimary)" />
      <!-- Drop sandbox/runtime-provided assemblies — merging them would clash with platform versions at runtime. -->
      <_TalxisMergeDeps Remove="@(_TalxisMergeDeps)"
                        Condition=" $([System.String]::Copy('$(_TalxisILRepackExcludePadded)').Contains(';%(Filename);'))
                                 Or $([System.String]::Copy('%(Filename)').StartsWith('Microsoft.Xrm.Sdk.'))
                                 Or $([System.String]::Copy('%(Filename)').StartsWith('System.')) " />
    </ItemGroup>

    <Message Importance="high"
             Text="TalxisMergeOutputAssembly: merging into $(AssemblyName).dll -> @(_TalxisMergeDeps->'%(Filename)', ', ')"
             Condition=" '@(_TalxisMergeDeps)' != '' " />
    <Message Importance="high"
             Text="TalxisMergeOutputAssembly: nothing to merge"
             Condition=" '@(_TalxisMergeDeps)' == '' " />

    <!-- Internalize=false: keep public type names so Dataverse reflection
         still finds IPlugin / CodeActivity / package-deployer types. -->
    <!-- LibraryPath needs the absolute path to OutDir so Mono.Cecil's
         resolver finds referenced assemblies regardless of CWD. -->
    <ILRepack Condition=" '@(_TalxisMergeDeps)' != '' "
              Parallel="true"
              Internalize="false"
              InputAssemblies="$(_TalxisMergePrimaryRaw);@(_TalxisMergeDeps)"
              OutputFile="$(_TalxisMergeOutputDll)"
              KeyFile="$(AssemblyOriginatorKeyFile)"
              LibraryPath="$([System.IO.Path]::GetFullPath('$(OutDir)'))" />
  </Target>

</Project>
